{
  "name": "bat-signal",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time BMW 2002 auction monitoring, price prediction, and bidding intelligence platform",
  "workspaces": [
    "frontend",
    "scraper"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:scraper": "npm run dev --workspace=scraper",
    "dev:convex": "npx convex dev",
    "build:frontend": "npm run build --workspace=frontend",
    "build:scraper": "npm run build --workspace=scraper",
    "deploy:convex": "npx convex deploy",
    "lint": "npm run lint --workspaces --if-present"
  },
  "dependencies": {
    "convex": "^1.17.0"
  }
}
