# ===========================================
# BaT Signal — Environment Variables
# ===========================================
# Copy to .env.local and fill in values

# --- Convex ---
# Auto-generated by `npx convex dev` — don't set manually
# CONVEX_DEPLOYMENT=dev:your-deployment-name

# Frontend needs this (prefixed with VITE_ for Vite)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# --- Convex Environment Variables (set via `npx convex env set`) ---
# SCRAPER_SECRET=generate-a-random-secret-here
# ML_SERVICE_URL=https://bat-ml-xxx.up.railway.app

# --- Scraper (Railway) ---
CONVEX_SITE_URL=https://your-deployment.convex.site
SCRAPER_SECRET=generate-a-random-secret-here
BAT_BASE_URL=https://bringatrailer.com
PROXY_URL=
# Optional: residential proxy for anti-detection

# --- ML Service (Railway) ---
# MODEL_PATH=/app/models/current.pkl
# CONVEX_URL=https://your-deployment.convex.cloud

# --- Railway ---
# RAILWAY_TOKEN=your-railway-api-token

# --- Vercel ---
# VERCEL_TOKEN=your-vercel-token

# --- Monitoring ---
# SENTRY_DSN=https://xxx@sentry.io/xxx
